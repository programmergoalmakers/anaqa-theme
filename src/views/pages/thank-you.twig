{% extends "layouts.master" %}

{% block content %}
    <div class="container mx-auto px-4 py-16 text-center">
        <div class="max-w-md mx-auto">
            <span class="sicon-check-circle text-5xl text-green-500 mb-4 block"></span>
            <h1 class="text-2xl font-light mb-4">{{ 'thank_you' | t }}</h1>
            <p class="text-gray-500 mb-8">{{ 'order_placed' | t }}</p>
            <a href="{{ store.url }}" class="anaqa-btn">{{ 'continue_shopping' | t }}</a>
        </div>
    </div>
{% endblock %}
