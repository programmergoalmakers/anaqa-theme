{#
  Product Single Page
  Variables: product (object)
#}
{% extends "layouts.master" %}

{% block content %}
    <div class="container mx-auto px-4 py-6 md:py-10">
        {% if theme.settings.get('product_show_breadcrumbs', true) %}
            <div class="anaqa-breadcrumb">
                <a href="{{ store.url }}">{{ 'home' | t }}</a>
                <span>/</span>
                {% if product.category %}
                    <a href="{{ product.category.url }}">{{ product.category.name }}</a>
                    <span>/</span>
                {% endif %}
                <span class="text-gray-700">{{ product.name }}</span>
            </div>
        {% endif %}

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12">
            <div class="anaqa-product-gallery">
                <div class="anaqa-product-gallery-main">
                    <img src="{{ product.images[0] ?: theme.settings.get('placeholder') }}" alt="{{ product.name }}" loading="eager">
                </div>
                {% if product.images|length > 1 %}
                    <div class="grid grid-cols-4 gap-2 mt-4">
                        {% for image in product.images %}
                            <div class="aspect-square overflow-hidden border border-gray-100 cursor-pointer hover:border-dark transition-colors">
                                <img src="{{ image }}" alt="{{ product.name }}" loading="lazy" class="w-full h-full object-cover">
                            </div>
                        {% endfor %}
                    </div>
                {% endif %}
            </div>

            <div class="anaqa-product-info">
                <h1>{{ product.name }}</h1>

                <div class="price-display">
                    {% if product.discount_price %}
                        <span class="old">{{ product.regular_price | number_format(2) }} {{ 'currency' | t }}</span>
                        <span class="current">{{ product.discount_price | number_format(2) }} {{ 'currency' | t }}</span>
                        {% set disc = ((product.regular_price - product.discount_price) / product.regular_price * 100) | round %}
                        <span class="discount-badge">-{{ disc }}%</span>
                    {% else %}
                        <span class="current">{{ product.regular_price | number_format(2) }} {{ 'currency' | t }}</span>
                    {% endif %}
                </div>

                {% if product.rating %}
                    <div class="flex items-center gap-2">
                        <div class="flex text-gold">
                            {% for i in 1..5 %}
                                <span class="{{ i <= product.rating ? 'sicon-star' : 'sicon-star-o' }} text-sm"></span>
                            {% endfor %}
                        </div>
                        {% if product.reviews_count %}
                            <span class="text-xs text-gray-400">({{ product.reviews_count }} {{ 'reviews' | t }})</span>
                        {% endif %}
                    </div>
                {% endif %}

                <div class="variant-selector">
                    {% if product.variants is not empty %}
                        {% for variant in product.variants %}
                            <div>
                                <label class="variant-label">{{ variant.name }}</label>
                                <div class="variant-options">
                                    {% for option in variant.options %}
                                        <button class="variant-option" data-variant="{{ variant.id }}" data-value="{{ option.id }}">
                                            {{ option.name }}
                                        </button>
                                    {% endfor %}
                                </div>
                            </div>
                        {% endfor %}
                    {% endif %}
                </div>

                <div class="add-to-cart-section">
                    <div class="flex items-center gap-4 mb-4">
                        <div class="flex items-center border border-gray-200">
                            <button class="px-4 py-3 text-sm hover:bg-gray-50" onclick="updateQty(-1)">-</button>
                            <input type="number" id="qty-input" value="1" min="1" max="{{ product.quantity }}" class="w-16 text-center text-sm border-x border-gray-200 py-3" readonly>
                            <button class="px-4 py-3 text-sm hover:bg-gray-50" onclick="updateQty(1)">+</button>
                        </div>
                    </div>
                    <button class="anaqa-btn w-full text-center" onclick="addToCart({{ product.id }})">
                        {{ 'add_to_cart' | t }}
                    </button>
                </div>

                <div class="trust-messages">
                    <span class="trust-message">
                        <span class="sicon-truck text-accent"></span>
                        {{ 'fast_shipping' | t }}
                    </span>
                    <span class="trust-message">
                        <span class="sicon-shield-check text-accent"></span>
                        {{ 'secure_payment' | t }}
                    </span>
                    <span class="trust-message">
                        <span class="sicon-refresh text-accent"></span>
                        {{ 'easy_return' | t }}
                    </span>
                </div>
            </div>
        </div>

        <div class="mt-12 md:mt-16">
            <div class="border-b border-gray-200">
                <div class="flex gap-8">
                    <button class="tab-btn active pb-4 text-sm font-medium border-b-2 border-dark" data-tab="description" onclick="switchTab('description')">
                        {{ 'description' | t }}
                    </button>
                    {% if product.specifications %}
                        <button class="tab-btn pb-4 text-sm font-medium text-gray-400 hover:text-dark transition-colors" data-tab="specs" onclick="switchTab('specs')">
                            {{ 'specifications' | t }}
                        </button>
                    {% endif %}
                    <button class="tab-btn pb-4 text-sm font-medium text-gray-400 hover:text-dark transition-colors" data-tab="reviews" onclick="switchTab('reviews')">
                        {{ 'reviews' | t }}
                    </button>
                </div>
            </div>
            <div class="py-8">
                <div id="tab-description" class="tab-content">
                    <div class="anaqa-product-description">
                        {{ product.description | raw }}
                    </div>
                </div>
                {% if product.specifications %}
                    <div id="tab-specs" class="tab-content" style="display:none;">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            {% for spec in product.specifications %}
                                <div class="flex justify-between py-3 border-b border-gray-100">
                                    <span class="text-sm text-gray-500">{{ spec.name }}</span>
                                    <span class="text-sm font-medium">{{ spec.value }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}
                <div id="tab-reviews" class="tab-content" style="display:none;">
                    <salla-reviews product-id="{{ product.id }}"></salla-reviews>
                </div>
            </div>
        </div>

        {% if product.related_products is not empty %}
            <section class="mt-12 md:mt-16">
                <div class="anaqa-section-title">
                    <h2>{{ 'related_products' | t }}</h2>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
                    {% for related in product.related_products %}
                        {% include "pages.partials.product.card" with {product: related} %}
                    {% endfor %}
                </div>
            </section>
        {% endif %}
    </div>

    {% if theme.settings.get('sticky_add_to_cart', true) %}
        <div class="anaqa-sticky-cart-bar">
            <div class="flex items-center justify-between gap-4">
                <div>
                    {% if product.discount_price %}
                        <span class="text-sm text-gray-400 line-through">{{ product.regular_price | number_format(2) }} {{ 'currency' | t }}</span>
                        <span class="text-base font-bold block">{{ product.discount_price | number_format(2) }} {{ 'currency' | t }}</span>
                    {% else %}
                        <span class="text-base font-bold">{{ product.regular_price | number_format(2) }} {{ 'currency' | t }}</span>
                    {% endif %}
                </div>
                <button class="anaqa-btn text-sm px-6 py-2" onclick="addToCart({{ product.id }})">
                    {{ 'add_to_cart' | t }}
                </button>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block scripts %}
    <script defer src="{{ 'product.js' | asset }}"></script>
{% endblock %}
