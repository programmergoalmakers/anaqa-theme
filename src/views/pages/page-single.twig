{#
  Single Page (About, Privacy, etc.)
  Variables: page (object)
#}
{% extends "layouts.master" %}

{% block content %}
    <div class="container mx-auto px-4 py-6 md:py-10">
        <div class="anaqa-breadcrumb">
            <a href="{{ store.url }}">{{ 'home' | t }}</a>
            <span>/</span>
            <span class="text-gray-700">{{ page.title | raw }}</span>
        </div>
        <article class="max-w-3xl mx-auto">
            <h1 class="text-2xl md:text-3xl font-light mb-8">{{ page.title | raw }}</h1>
            <div class="prose prose-sm max-w-none">
                {{ page.content | raw }}
            </div>
        </article>
    </div>
{% endblock %}
