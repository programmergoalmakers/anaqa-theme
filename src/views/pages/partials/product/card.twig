{#
  Product Card Partial
  Expects: product (object)
#}
<div class="anaqa-product-card">
    <div class="anaqa-product-card-image">
        <a href="{{ product.url }}">
            <img src="{{ product.images[0] ?: theme.settings.get('placeholder') }}" alt="{{ product.name }}" loading="lazy">
        </a>
        <div class="anaqa-product-card-badge">
            {% if product.discount_price %}
                {% set disc = ((product.regular_price - product.discount_price) / product.regular_price * 100) | round %}
                <span class="badge badge-sale">-{{ disc }}%</span>
            {% elseif product.is_new %}
                <span class="badge badge-new">{{ 'new' | t }}</span>
            {% endif %}
        </div>
        <div class="anaqa-product-card-actions md:hidden">
            <button class="anaqa-btn w-full text-xs py-2" onclick="addToCart({{ product.id }})">
                {{ 'add_to_cart' | t }}
            </button>
        </div>
    </div>
    <div class="anaqa-product-card-body">
        <a href="{{ product.url }}">
            <h3 class="product-name">{{ product.name }}</h3>
        </a>
        <div class="product-price">
            {% if product.discount_price %}
                <span class="old">{{ product.regular_price | number_format(2) }} {{ 'currency' | t }}</span>
                <span class="current">{{ product.discount_price | number_format(2) }} {{ 'currency' | t }}</span>
            {% else %}
                <span class="current">{{ product.regular_price | number_format(2) }} {{ 'currency' | t }}</span>
            {% endif %}
        </div>
    </div>
</div>
